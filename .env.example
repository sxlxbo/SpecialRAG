# ── LLM API Keys ──────────────────────────────────────────────────────────
# At least one is required. nanobot + PageIndex both read OPENAI_API_KEY.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# For LiteLLM multi-provider routing, set provider-specific keys:
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=...

# ── Document Workspace ────────────────────────────────────────────────────
# Directory where indexed PDF structures and chunk data are stored.
# Mount as a Docker volume for persistence.
DOC_WORKSPACE=./doc_workspace

# ── Gateway ───────────────────────────────────────────────────────────────
# Host and port for the nanobot WebUI gateway.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8765

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
